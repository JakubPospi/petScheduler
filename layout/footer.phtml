<style>
    /* 1. Důležité nastavení pro to, aby patička držela úplně dole */
    html, body {
        height: 100%;
        margin: 0;
    }
    
    body {
        display: flex;
        flex-direction: column;
        /* Zde máš nastavené své obrázkové pozadí */
        background-image: url('./imgs/background-image.png'); 
        background-size: cover;
        background-position: center bottom;
        background-repeat: no-repeat;
        background-attachment: fixed;
        font-family: 'Segoe UI', sans-serif;
    }

    /* 2. Tento kontejner musí obalovat VŠECHEN obsah pod headerem (nadpisy, tabulky atd.) */
    .main-content {
        flex: 1; /* Roztáhne obsah a odtlačí footer dolů */
        padding: 40px 20px;
    }

    /* 3. Stylování samotné lišty patičky */
    footer {
        display: flex;
        justify-content: center;
        gap: 30px; /* Mezera mezi údaji v liště */
        padding: 15px 20px;
        margin-top: auto; /* Pojistka pro držení dole */
        width: 100%;
        box-sizing: border-box;
        
        /* Moderní poloprůhledná lišta, která rozmaže trávu pod sebou (vlastní lišta) */
        background: rgba(255, 255, 255, 0.4); 
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        
        /* Jemná linka na horním okraji lišty pro oddělení */
        border-top: 1px solid rgba(255, 255, 255, 0.3);
        
        /* Barva písma – tmavě šedá/černá, aby byla na světlé liště dobře vidět */
        color: #1e293b; 
        font-size: 0.9rem;
        font-weight: 500;
    }

    /* Volitelné: styl pro ikony nebo text v patičce */
    footer span {
        display: inline-flex;
        align-items: center;
    }
</style>

</div>

<footer>
    <span>&copy; Vivicta</span>
    <span>&phone; +420 123 456 789</span>
    <span>&commat; vicita@email.com</span>
</footer>

</body>
</html>