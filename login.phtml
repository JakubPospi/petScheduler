<?php
session_start();

$chyba = false;

$conn = new mysqli("localhost", "root", "", "appkakrmeni");
if ($conn->connect_error) 
    die("Chyba přístupu k databázi!");

if (isset($_POST['username'])) {
    $username = $_POST['username'];
    $password = $_POST['password'];
    $passHASH = sha1($password); 
    $stmt = $conn->prepare("SELECT * FROM users WHERE username = ? AND passwd = ?");
    $stmt->bind_param("ss", $username, $passHASH);
    
    $stmt->execute();
    $result = $stmt->get_result();     
    $uzivatel = $result->fetch_assoc(); 

    if ($uzivatel) {
        $_SESSION['uzivatel'] = $uzivatel['username'];
        header("Location: index.phhtml");
        exit;
    } 
    else {
        $chyba = true;
    }
    $stmt->close();
}

?>

