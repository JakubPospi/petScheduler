<?php
$role = (int)$uzivatel['role_id'];
$isAdmin  = $role === 1;
$isParent = $role === 2;
$isChild  = $role === 3;
$canDelete        = $isAdmin; // parent+admin can delete
$canUncomplete    = $isAdmin || $isParent || $isChild;              // only admin can undo completed
$canComplete      = !$isChild ? true : true; // everyone can complete their own
?>

<div class="tasks-board">

    <?php
    $columns = [
        ['label' => 'Čeká',      'tasks' => $pendingTasks, 'statusText' => 'Čeká',       'statusClass' => 'pending'],
        ['label' => 'Po termínu','tasks' => $overdueTasks, 'statusText' => 'Po termínu', 'statusClass' => 'overdue'],
        ['label' => 'Splněno',   'tasks' => $doneTasks,    'statusText' => 'Splněno',    'statusClass' => 'done'],
    ];
    foreach ($columns as $col):
    ?>
    <div class="tasks-column">
        <h3 class="column-title">
            <?= $col['label'] ?>
            <span class="task-count"><?= count($col['tasks']) ?></span>
        </h3>
        <div class="tasks-grid">
            <?php foreach ($col['tasks'] as $task): ?>
            <div class="task-card">
                <div class="task-top">
                    <div class="task-type"><?= htmlspecialchars($task['type_name']) ?></div>
                    <div class="status <?= $col['statusClass'] ?>"><?= $col['statusText'] ?></div>
                </div>
                <div class="task-title">Úkol #<?= $task['id'] ?></div>
                <div class="task-description"><?= htmlspecialchars($task['note']) ?></div>
                <div class="task-info">
                    <div class="info-row">
                        <div class="info-label">Má splnit</div>
                        <div class="info-value"><?= htmlspecialchars($task['user_name']) ?></div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Zvíře</div>
                        <div class="info-value">🐾 <?= htmlspecialchars($task['animal_name']) ?></div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Vytvořeno</div>
                        <div class="info-value"><?= date('d. m. Y H:i', strtotime($task['taskCreated'])) ?></div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Splatnost</div>
                        <div class="info-value"><?= date('d. m. Y', strtotime($task['taskTime'])) ?></div>
                    </div>
                </div>
                <div class="task-actions">

                    <?php if ($col['statusClass'] === 'done'): ?>
                        <?php if ($canUncomplete ): ?>
                        <!-- Admin only: undo completed task -->
                        <form action="undo_task.php" method="POST" style="flex:1;display:flex;">
                            <input type="hidden" name="task_id" value="<?= $task['id'] ?>">
                            <input type="hidden" name="action" value="undo">
                            <button class="btn btn-undo">↩ Vrátit zpět</button>
                        </form>
                        <?php endif; ?>
                        <?php if ($canDelete): ?>
                        <!-- Parent/Admin: delete completed task -->
                        <form action="delete_task.php" method="POST" style="flex:1;display:flex;">
                            <input type="hidden" name="task_id" value="<?= $task['id'] ?>">
                            <button type="submit" class="btn btn-delete" onclick="return confirm('Smazat úkol?');">🗑 Smazat</button>
                        </form>
                        <?php endif; ?>
                        <?php if ($isChild): ?>
                        <div class="task-done-note">✓ Splněno</div>
                        <?php endif; ?>

                    <?php else: ?>
                        <!-- Complete button — everyone sees this -->
                        <form action="complete_task.php" method="POST" style="flex:1;display:flex;">
                            <input type="hidden" name="task_id" value="<?= $task['id'] ?>">
                            <button type="submit" class="btn btn-complete">✓ Splněno</button>
                        </form>
                        <?php if ($canDelete): ?>
                        <!-- Parent/Admin only: delete pending/overdue task -->
                        <form action="delete_task.php" method="POST" style="flex:1;display:flex;">
                            <input type="hidden" name="task_id" value="<?= $task['id'] ?>">
                            <button type="submit" class="btn btn-delete" onclick="return confirm('Smazat úkol?');">🗑 Smazat</button>
                        </form>
                        <?php endif; ?>
                    <?php endif; ?>

                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
    <?php endforeach; ?>

</div>

<?php if (!$isChild): ?>
<div style="margin-top: 20px;">
    <form action="./add_tasks.php">
        <button class="btn-add-main">+ Přidat úkol</button>
    </form>
</div>
<?php endif; ?>
