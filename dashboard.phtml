            <div class="info-label">Vytvořeno</div>
            <div class="info-value">
                <?= date('d. m. Y H:i', strtotime($task['taskCreated'])) ?>
            </div>
        </div>

        <div class="info-row">
            <div class="info-label">Splatnost</div>
            <div class="info-value">
                <?= date('d. m. Y', strtotime($task['taskTime'])) ?>
            </div>
        </div>

    </div>

