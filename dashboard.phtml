</head>
<body>


    <div class="dashboard-container">
        <div class="user-box">
            Aktuálně jsi přihlášen jako:
            <strong><?= $uzivatel["username"] ?></strong> <br>
            Patříš do rodiny: <strong><?= $nazev_rodiny?></strong>
            
        </div>

        <table class="prehled-ukolu">
  <thead>
