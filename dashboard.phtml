
<div class="dashboard-container">

    <div class="dashboard-header">

        <h1>Úkoly pro mazlíčky</h1>

        <p>
            Přehled všech aktuálních úkolů v rodině.
        </p>

    </div>

    <div class="tasks-grid">


        <div class="task-card">

            <div class="task-top">

                <div class="task-type">
                    🍖 Krmení
                </div>

                <div class="status pending" id="status1">
                    Čeká
                </div>

            </div>

            <div class="task-title">
                Nakrmit Alíka
            </div>

            <div class="task-info">

                <div class="info-row">

                    <div class="info-label">
                        Má splnit
                    </div>

                    <div class="info-value">
                        Jan Novák
                    </div>

                </div>

                <div class="info-row">

                    <div class="info-label">
                        Zvíře
                    </div>

                    <div class="info-value">
                        🐶 Alík (Pes)
                    </div>

                </div>

                <div class="info-row">

                    <div class="info-label">
                        Vytvořeno
                    </div>

                    <div class="info-value">
                        21. 5. 2026 09:15
                    </div>

                </div>

            </div>

            <div class="task-description">
                Nasypat granule do misky a doplnit čerstvou vodu.
            </div>

            <div class="task-actions">

                <button
                    class="btn btn-complete"
                    onclick="toggleComplete(this, 'status1')">

                    ✔ Splněno

                </button>

                <button class="btn btn-delete">

                    🗑 Smazat

                </button>

            </div>

        </div>


        <div class="task-card">

            <div class="task-top">

                <div class="task-type">
                    🚶 Procházka
                </div>

                <div class="status pending" id="status2">
                    Čeká
                </div>

            </div>

            <div class="task-title">
                Večerní venčení
            </div>

            <div class="task-info">

                <div class="info-row">

                    <div class="info-label">
                        Má splnit
                    </div>

                    <div class="info-value">
                        Petra Nováková
                    </div>

                </div>

                <div class="info-row">

                    <div class="info-label">
                        Zvíře
                    </div>

                    <div class="info-value">
                        🐕 Rex
                    </div>

                </div>

                <div class="info-row">

                    <div class="info-label">
                        Vytvořeno
                    </div>

                    <div class="info-value">
                        21. 5. 2026 18:00
                    </div>

                </div>

            </div>

            <div class="task-description">
                Minimálně 30 minut procházka v parku.
            </div>

            <div class="task-actions">

                <button
                    class="btn btn-complete"
                    onclick="toggleComplete(this, 'status2')">

                    ✔ Splněno

                </button>

                <button class="btn btn-delete">

                    🗑 Smazat

                </button>

            </div>

        </div>

    </div>

</div>

<script>

function toggleComplete(button, statusId){

    const status =
        document.getElementById(statusId);

    if(status.classList.contains('pending')){

        status.classList.remove('pending');
        status.classList.add('done');

        status.innerText = 'Splněno';

        button.innerText = '✔ Hotovo';

        button.style.opacity = '0.7';

    } else {

        status.classList.remove('done');
        status.classList.add('pending');

        status.innerText = 'Čeká';

        button.innerText = '✔ Splněno';

        button.style.opacity = '1';
    }
}

</script>
