<div class="tasks-grid">

<?php foreach ($tasks as $task): ?>

<?php
    $isOverdue = strtotime($task['taskTime']) < time();
    $isDone = $task['is_done'];
    $statusText = $isOverdue ? "Po termínu" : "Čeká";
    $statusClass = $isOverdue ? "overdue" : "pending";
    if($isDone === 1){
        $statusText = "Splněno";
        $statusClass = "done";
    }
    elseif($isDone === 0){
        $statusText = "Čeká";
        $statusClass = "pending";
    } 
    
?>

<div class="task-card">

    <div class="task-top">

        <div class="task-type">
            <?= htmlspecialchars($task['type_name']) ?>
        </div>

        <div class="status <?= $statusClass ?>">
            <?= $statusText ?>
        </div>

    </div>

    <div class="task-title">
        Úkol #<?= $task['id'] ?>
    </div>

    <div class="task-info">

        <div class="info-row">
            <div class="info-label">Má splnit</div>
            <div class="info-value">
                <?= htmlspecialchars($task['user_name']) ?>
            </div>
        </div>

        <div class="info-row">
            <div class="info-label">Zvíře</div>
            <div class="info-value">
                🐾 <?= htmlspecialchars($task['animal_name']) ?>
            </div>
        </div>

