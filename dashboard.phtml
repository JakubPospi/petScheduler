<div class="tasks-grid">

<?php foreach ($tasks as $task): ?>

<?php
    $isOverdue = strtotime($task['taskTime']) < time();
    $statusText = $isOverdue ? "Po termínu" : "Čeká";
    $statusClass = $isOverdue ? "overdue" : "pending";
?>

<div class="task-card">

    <div class="task-top">

        <div class="task-type">
            <?= htmlspecialchars($task['type_name']) ?>
        </div>

        <div class="status <?= $statusClass ?>">
            <?= $statusText ?>
        </div>

    </div>

    <div class="task-title">
        Úkol #<?= $task['id'] ?>
    </div>

    <div class="task-info">

        <div class="info-row">
            <div class="info-label">Má splnit</div>
            <div class="info-value">
                <?= htmlspecialchars($task['user_name']) ?>
            </div>
        </div>

        <div class="info-row">
            <div class="info-label">Zvíře</div>
            <div class="info-value">
                🐾 <?= htmlspecialchars($task['animal_name']) ?>
            </div>
        </div>

        <div class="info-row">
            <div class="info-label">Vytvořeno</div>
            <div class="info-value">
                <?= date('d. m. Y H:i', strtotime($task['taskCreated'])) ?>
            </div>
        </div>

        <div class="info-row">
            <div class="info-label">Splatnost</div>
            <div class="info-value">
                <?= date('d. m. Y', strtotime($task['taskTime'])) ?>
            </div>
        </div>

    </div>

    <div class="task-description">
        <?= htmlspecialchars($task['note']) ?>
    </div>

    <div class="task-actions">

        <button class="btn btn-complete"
                onclick="toggleComplete()">
            ✔ Splněno
        </button>

        <button class="btn btn-delete"
                onclick="deleteTask(this, <?= $task['id'] ?>)">
            🗑 Smazat
        </button>

    </div>

</div>

<?php endforeach; ?>

</div>

<script>

function toggleComplete(button, statusId){

    const status = document.getElementById(statusId);

    // pokud už je splněno, nic nedělej
    if(status.classList.contains('done')){
        return;
    }

    // označení jako splněno
    status.classList.remove('pending');
    status.classList.add('done');

    status.innerText = 'Splněno';

    button.innerText = '✔ Hotovo';

    button.style.opacity = '0.7';

    // deaktivace tlačítka
    button.disabled = true;
}

function deleteTask(button){

    // najde nejbližší kartičku úkolu
    const taskCard = button.closest('.task-card');

    // smaže ji ze stránky
    taskCard.remove();
}

</script>