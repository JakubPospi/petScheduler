                <option value="<?= $u['id'] ?>">
                    <?= htmlspecialchars($u['username']) ?>
                </option>
            <?php endforeach; ?>
        </select>
    </div>

    <div class="task-input">
        <label for="animal_id">Zvíře</label>
        <select name="animal_id" id="animal_id">
            <?php foreach($mazlicci as $mazlicek): ?>
                <option value="<?= $mazlicek['id'] ?>">
                    <?= htmlspecialchars($mazlicek['name']) ?>
                </option>
            <?php endforeach; ?>
        </select>
