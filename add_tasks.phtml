<?php
    // Only fetch users and animals from the SAME family
    $family_id = $uzivatel['family_id'];

    $stUkoly = $db->prepare("SELECT * FROM task_type");
    $stUkoly->execute();
    $ukoly = $stUkoly->get_result();

    // Only family members
    $stUzivatel = $db->prepare("SELECT id, username FROM users WHERE family_id = ?");
    $stUzivatel->execute([$family_id]);
    $uzivatele = $stUzivatel->get_result();

    // Only family animals
    $stMazlicci = $db->prepare("SELECT id, name FROM animals WHERE family_id = ?");
    $stMazlicci->execute([$family_id]);
    $mazlicci = $stMazlicci->get_result();
?>

<?php if($uzivatel['role_id'] === 1 || $uzivatel['role_id'] === 2): ?>
<h1>Vytvoření nového úkolu</h1>
<div class="task-create-form">

<form method="POST">
    <div class="task-input">
        <label for="task_type">Typ úkolu</label>
